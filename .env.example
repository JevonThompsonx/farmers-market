# MongoDB (legacy Express app — to be replaced by Turso in Phase 3)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority

# Turso (Phase 3+)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Auth.js (Phase 5+)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloudinary (Phase 3+)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Unsplash (Phase 3+)
UNSPLASH_ACCESS_KEY=

# Rate limiting via Upstash (Phase 4+)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
PORT=8080
